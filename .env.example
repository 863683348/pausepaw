# PausePaw 环境变量示例（复制为 .env 并按需修改；Node 不会自动读取，请在启动命令中注入）
PORT=3000
# 生产务必改成随机长字符串，否则 Token 可被伪造
JWT_SECRET=please-use-a-long-random-string-in-production
# SQLite 数据库文件路径（容器内建议挂卷到 /app/data）
DB_PATH=/app/data/app.db
# 站点公开域名（用于 SEO 的 canonical/sitemap/og 链接，部署到公网必设）
SITE_URL=https://your-domain.com
# 运行环境：设为 production 才注入 GA4/Clarity 分析脚本（localhost 不注入，避免污染数据）
NODE_ENV=production
# 项 7：分析监控（留空则不加载）
# Google Analytics 4 衡量 ID，形如 G-XXXXXXXXXX（https://analytics.google.com 创建）
GA4_MEASUREMENT_ID=
# Microsoft Clarity 项目 ID（免费热力图+回放，https://clarity.microsoft.com 创建）
CLARITY_ID=

# 项 5：Google 登录（留空则前端按钮隐藏）。
# 在 Google Cloud Console 创建 OAuth 客户端（类型：Web 应用），
# “已获授权的重定向 URI” 填：{SITE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 回调地址（默认 = SITE_URL + /api/auth/google/callback，一般无需改）
GOOGLE_REDIRECT_URI=

# 项 6：PayPal 支付（订阅模式）。留空则支付功能未启用（前端不显示订阅）。
# 在 PayPal Developer 创建 App（Sandbox 或 Live），拿到 Client ID / Secret。
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# 环境：sandbox（默认，测试用）或 live（真实收款）
PAYPAL_MODE=sandbox
# 在 PayPal 后台创建的 Plan ID（需先建 Product + Plan，周期建议月付）。
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_FAMILY=
# Webhook ID（生产建议配置，用于校验签名；本地测试可留空）
PAYPAL_WEBHOOK_ID=

